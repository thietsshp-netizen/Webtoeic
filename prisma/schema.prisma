generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String            @id @default(cuid())
  name             String?
  email            String?           @unique
  emailVerified    DateTime?
  image            String?
  password         String?
  role             Role              @default(USER)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  displayName      String?
  accountExpiresAt DateTime?         @default(now())
  activeSessionId  String?
  lastHeartbeatAt  DateTime?
  accounts         Account[]
  enrollments      Enrollment[]
  fullTestAttempts FullTestAttempt[]
  ipHistories      IPHistory[]
  lessonProgresses LessonProgress[]
  questionAttempts QuestionAttempt[]
  sessions         Session[]
  devices          UserDevice[]
  userVocabs       UserVocabulary[]
  vocabBookmarks   VocabBookmark[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model IPHistory {
  id        String   @id @default(cuid())
  userId    String
  ipAddress String
  lastSeen  DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ipAddress])
  @@index([userId])
}

model Course {
  id          String       @id @default(cuid())
  title       String
  description String?
  coverImage  String?
  isPublic    Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  content     String?
  books       Book[]
  enrollments Enrollment[]
  sections    Section[]
}

model Book {
  id        String    @id @default(cuid())
  courseId  String
  title     String
  order     Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  course    Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  sections  Section[]

  @@index([courseId])
}

model Section {
  id        String   @id @default(cuid())
  courseId  String
  title     String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  bookId    String?
  lessons   Lesson[]
  book      Book?    @relation(fields: [bookId], references: [id], onDelete: Cascade)
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([bookId])
}

model Lesson {
  id               String            @id @default(cuid())
  sectionId        String
  title            String
  contentType      String            @default("TEXT")
  content          String?
  videoUrl         String?
  toeicTestId      String?
  videoExplanation Json?             // Trường mới: Lưu trữ cấu hình video chữa & mốc thời gian dạng tự do (nullable)
  isPreview        Boolean           @default(false)
  order            Int               @default(0)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  vocabDayId       String?
  section          Section           @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  toeicTest        ToeicTest?        @relation(fields: [toeicTestId], references: [id])
  vocabDay         VocabDay?         @relation(fields: [vocabDayId], references: [id])
  progresses       LessonProgress[]
  questionAttempts QuestionAttempt[]

  @@index([sectionId])
  @@index([toeicTestId])
  @@index([vocabDayId])
}

model Enrollment {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

model ToeicTest {
  id          String      @id @default(cuid())
  title       String
  description String?
  isPublished Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  lessons     Lesson[]
  parts       ToeicPart[]
}

model ToeicPart {
  id         String               @id @default(cuid())
  testId     String
  partNumber Int
  title      String?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  test       ToeicTest            @relation(fields: [testId], references: [id], onDelete: Cascade)
  groups     ToeicQuestionGroup[]

  @@index([testId])
}

model ToeicQuestionGroup {
  id          String          @id @default(cuid())
  partId      String
  audioUrl    String?
  imageUrl    String?
  passageText String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  transcript  String?
  metadata    Json?
  questions   ToeicQuestion[]
  part        ToeicPart       @relation(fields: [partId], references: [id], onDelete: Cascade)

  @@index([partId])
}

model ToeicQuestion {
  id            String             @id @default(cuid())
  groupId       String
  questionNo    Int
  questionText  String?
  optionA       String
  optionB       String
  optionC       String
  optionD       String?
  correctAnswer String
  explanation   String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  metadata      Json?
  attempts      QuestionAttempt[]
  group         ToeicQuestionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId])
}

model LessonProgress {
  id          String    @id @default(cuid())
  userId      String
  lessonId    String
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lesson      Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
}

model QuestionAttempt {
  id         String        @id @default(cuid())
  userId     String
  questionId String
  lessonId   String?
  isCorrect  Boolean
  userAnswer String
  isFlagged  Boolean       @default(false)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  flagColor  String?
  courseId   String?
  flagNote   String?
  lesson     Lesson?       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  question   ToeicQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId, lessonId])
  @@index([userId])
  @@index([lessonId])
  @@index([questionId])
  @@index([courseId])
}

model FullTestAttempt {
  id              String   @id @default(cuid())
  userId          String
  lessonId        String?
  testId          String?
  lcScore         Int
  rcScore         Int
  totalScore      Int
  correctCount    Int
  incorrectCount  Int
  unansweredCount Int
  timeSpent       Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VocabDay {
  id        String          @id @default(cuid())
  dayNumber Int             @unique
  title     String
  data      String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  lessons   Lesson[]
  bookmarks VocabBookmark[]
}

model VocabBookmark {
  id         String   @id @default(cuid())
  userId     String
  vocabDayId String
  wordId     Int
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  vocabDay   VocabDay @relation(fields: [vocabDayId], references: [id], onDelete: Cascade)

  @@unique([userId, vocabDayId, wordId])
  @@index([userId])
  @@index([vocabDayId])
}

model Dictionary {
  id        String   @id @default(cuid())
  word      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  data      Json?

  @@index([word])
}

model ContentLog {
  id         String   @id @default(cuid())
  lessonId   String?
  target     String
  targetId   String
  fieldPath  String
  oldValue   Json?
  newValue   Json?
  adminEmail String
  createdAt  DateTime @default(now())

  @@index([targetId])
  @@index([adminEmail])
}

model UserVocabulary {
  id                 String    @id @default(cuid())
  userId             String
  word               String
  partOfSpeech       String?
  definition         String
  translation        String
  ipa                String?
  example            String?
  exampleTranslation String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  antonyms           String?
  collocations       String?
  synonyms           String?
  isUnlearned        Boolean   @default(true)
  isStarred          Boolean   @default(true)
  wordFamily         String?
  lastReviewedAt     DateTime?
  nextReviewDate     DateTime  @default(now())
  srsBox             Int       @default(1)
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([word])
}

model UserDevice {
  id        String   @id @default(cuid())
  userId    String
  deviceId  String
  type      String
  model     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@index([userId])
}

enum Role {
  USER
  ADMIN
}
